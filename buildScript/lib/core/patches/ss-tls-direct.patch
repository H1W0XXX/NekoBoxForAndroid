@@ -0,0 +1,375 @@
+package outbound
+
+import (
+	"bytes"
+	"io"
+	"net"
+	"sync"
+	"time"
+)
+
+const (
+	tlsDirectMaxObservationPackets  = 32
+	tlsDirectMaxRecordLen           = 0x4000 + 0x0800
+	tlsDirectServerHelloScanTailLen = 8
+)
+
+var tlsDirectMarker = []byte("\x00ss-rust-tls-direct-v1\xff")
+
+type shadowsocksTLSDirectConn struct {
+	net.Conn
+	rawConn net.Conn
+
+	readAccess sync.Mutex
+	readPlain  bool
+	readBuffer []byte
+
+	writeAccess sync.Mutex
+	writePlain  bool
+
+	stateAccess sync.Mutex
+	state       tlsDirectState
+}
+
+func newShadowsocksTLSDirectConn(conn net.Conn, rawConn net.Conn) net.Conn {
+	return &shadowsocksTLSDirectConn{
+		Conn:    conn,
+		rawConn: rawConn,
+	}
+}
+
+func (c *shadowsocksTLSDirectConn) Read(p []byte) (int, error) {
+	c.readAccess.Lock()
+	defer c.readAccess.Unlock()
+
+	if len(p) == 0 {
+		return 0, nil
+	}
+
+	if len(c.readBuffer) > 0 {
+		n := copy(p, c.readBuffer)
+		c.readBuffer = c.readBuffer[n:]
+		return n, nil
+	}
+
+	if c.readPlain {
+		return c.rawConn.Read(p)
+	}
+
+	buffer := make([]byte, 16*1024)
+	n, err := c.Conn.Read(buffer)
+	if n > 0 {
+		data := buffer[:n]
+		if bytes.HasPrefix(data, tlsDirectMarker) {
+			payload := data[len(tlsDirectMarker):]
+			c.readPlain = true
+			n = copy(p, payload)
+			if n < len(payload) {
+				c.readBuffer = append(c.readBuffer[:0], payload[n:]...)
+			}
+			return n, nil
+		}
+		c.observe(data)
+		n = copy(p, data)
+		if n < len(data) {
+			c.readBuffer = append(c.readBuffer[:0], data[n:]...)
+		}
+		return n, nil
+	}
+	return n, err
+}
+
+func (c *shadowsocksTLSDirectConn) Write(p []byte) (int, error) {
+	c.writeAccess.Lock()
+	defer c.writeAccess.Unlock()
+
+	if c.writePlain {
+		return c.rawConn.Write(p)
+	}
+
+	if c.shouldSwitchToDirect(p) {
+		buffer := make([]byte, 0, len(tlsDirectMarker)+len(p))
+		buffer = append(buffer, tlsDirectMarker...)
+		buffer = append(buffer, p...)
+		if err := writeFull(c.Conn, buffer); err != nil {
+			return 0, err
+		}
+		c.writePlain = true
+		return len(p), nil
+	}
+
+	return c.Conn.Write(p)
+}
+
+func (c *shadowsocksTLSDirectConn) observe(data []byte) {
+	c.stateAccess.Lock()
+	defer c.stateAccess.Unlock()
+	c.state.observe(data)
+}
+
+func (c *shadowsocksTLSDirectConn) shouldSwitchToDirect(data []byte) bool {
+	c.stateAccess.Lock()
+	defer c.stateAccess.Unlock()
+	return c.state.shouldSwitchToDirect(data)
+}
+
+func (c *shadowsocksTLSDirectConn) Close() error {
+	return c.Conn.Close()
+}
+
+func (c *shadowsocksTLSDirectConn) LocalAddr() net.Addr {
+	return c.Conn.LocalAddr()
+}
+
+func (c *shadowsocksTLSDirectConn) RemoteAddr() net.Addr {
+	return c.Conn.RemoteAddr()
+}
+
+func (c *shadowsocksTLSDirectConn) SetDeadline(t time.Time) error {
+	return c.Conn.SetDeadline(t)
+}
+
+func (c *shadowsocksTLSDirectConn) SetReadDeadline(t time.Time) error {
+	return c.Conn.SetReadDeadline(t)
+}
+
+func (c *shadowsocksTLSDirectConn) SetWriteDeadline(t time.Time) error {
+	return c.Conn.SetWriteDeadline(t)
+}
+
+type tlsDirectState struct {
+	initialized               bool
+	packetsSeen               int
+	packetsLeftToInspect      int
+	tlsSeen                   bool
+	handshakeSeen             bool
+	clientHelloSeen           bool
+	serverHelloSeen           bool
+	tls12OrAbove              bool
+	tls13Seen                 bool
+	handshakeConfirmed        bool
+	invalidTLS                bool
+	switched                  bool
+	remainingServerHelloBytes int
+	serverHelloScanTail       []byte
+}
+
+func (s *tlsDirectState) ensureInitialized() {
+	if s.initialized {
+		return
+	}
+	s.initialized = true
+	s.packetsLeftToInspect = tlsDirectMaxObservationPackets
+}
+
+func (s *tlsDirectState) observe(data []byte) {
+	if len(data) == 0 {
+		return
+	}
+
+	s.ensureInitialized()
+	s.packetsSeen++
+	if s.packetsLeftToInspect > 0 {
+		s.packetsLeftToInspect--
+	}
+
+	if s.invalidTLS || s.switched {
+		return
+	}
+
+	for pos := 0; pos < len(data) && s.shouldContinueObserving(); {
+		if s.remainingServerHelloBytes > 0 {
+			consumed := s.consumeServerHelloBytes(data[pos:])
+			pos += consumed
+			continue
+		}
+
+		if len(data)-pos < 5 {
+			break
+		}
+
+		recordType := data[pos]
+		major := data[pos+1]
+		minor := data[pos+2]
+		if !isTLSRecordVersion(major, minor) {
+			break
+		}
+
+		recordLen := int(data[pos+3])<<8 | int(data[pos+4])
+		if recordLen > tlsDirectMaxRecordLen {
+			s.invalidTLS = true
+			break
+		}
+
+		totalLen := 5 + recordLen
+		available := len(data) - pos
+		if available > totalLen {
+			available = totalLen
+		}
+		record := data[pos : pos+available]
+		s.processRecord(recordType, minor, record, totalLen, available == totalLen)
+		pos += available
+
+		if available < totalLen {
+			break
+		}
+	}
+}
+
+func (s *tlsDirectState) shouldSwitchToDirect(data []byte) bool {
+	s.observe(data)
+	completeTLS := isCompleteTLSApplicationData(data)
+	directReady := s.handshakeConfirmed &&
+		!s.invalidTLS &&
+		s.serverHelloSeen &&
+		(s.tls13Seen || s.tls12OrAbove)
+	decision := !s.switched && directReady && completeTLS
+	if decision {
+		s.switched = true
+	}
+	return decision
+}
+
+func (s *tlsDirectState) shouldContinueObserving() bool {
+	return !s.handshakeConfirmed &&
+		!s.invalidTLS &&
+		(s.remainingServerHelloBytes > 0 || s.packetsLeftToInspect > 0)
+}
+
+func (s *tlsDirectState) processRecord(recordType byte, minor byte, record []byte, totalLen int, isCompleteRecord bool) {
+	s.tlsSeen = true
+
+	if recordType != 0x16 {
+		return
+	}
+
+	s.handshakeSeen = true
+	s.tls12OrAbove = minor >= 0x03
+
+	if len(record) < 6 {
+		return
+	}
+
+	handshakeType := record[5]
+	switch handshakeType {
+	case 0x01:
+		s.clientHelloSeen = true
+	case 0x02:
+		s.serverHelloSeen = true
+		s.tls12OrAbove = minor >= 0x03
+		s.remainingServerHelloBytes = totalLen
+		s.serverHelloScanTail = s.serverHelloScanTail[:0]
+		consumed := s.consumeServerHelloBytes(record)
+		if consumed < len(record) || !isCompleteRecord {
+			return
+		}
+	}
+}
+
+func (s *tlsDirectState) consumeServerHelloBytes(data []byte) int {
+	if s.remainingServerHelloBytes == 0 || len(data) == 0 {
+		return 0
+	}
+
+	consume := s.remainingServerHelloBytes
+	if consume > len(data) {
+		consume = len(data)
+	}
+	slice := data[:consume]
+	s.scanServerHelloBytes(slice)
+	s.remainingServerHelloBytes -= consume
+	if s.remainingServerHelloBytes == 0 {
+		s.handshakeConfirmed = s.serverHelloSeen && s.tlsSeen
+		s.serverHelloScanTail = s.serverHelloScanTail[:0]
+	}
+	return consume
+}
+
+func (s *tlsDirectState) scanServerHelloBytes(data []byte) {
+	if len(data) == 0 {
+		return
+	}
+
+	if s.tls13Seen {
+		s.updateServerHelloScanTail(data)
+		return
+	}
+
+	combined := make([]byte, 0, len(s.serverHelloScanTail)+len(data))
+	combined = append(combined, s.serverHelloScanTail...)
+	combined = append(combined, data...)
+	if tls13SupportedVersionsSeen(combined) {
+		s.tls13Seen = true
+	}
+	s.updateServerHelloScanTail(combined)
+}
+
+func (s *tlsDirectState) updateServerHelloScanTail(data []byte) {
+	keep := len(data)
+	if keep > tlsDirectServerHelloScanTailLen {
+		keep = tlsDirectServerHelloScanTailLen
+	}
+	s.serverHelloScanTail = append(s.serverHelloScanTail[:0], data[len(data)-keep:]...)
+}
+
+func isCompleteTLSApplicationData(data []byte) bool {
+	for pos := 0; pos < len(data); {
+		if len(data)-pos < 5 {
+			return false
+		}
+		if data[pos] != 0x17 || !isTLSRecordVersion(data[pos+1], data[pos+2]) {
+			return false
+		}
+		recordLen := int(data[pos+3])<<8 | int(data[pos+4])
+		pos += 5
+		if len(data)-pos < recordLen {
+			return false
+		}
+		pos += recordLen
+	}
+	return true
+}
+
+func isTLSRecordVersion(major byte, minor byte) bool {
+	return major == 0x03 && minor >= 0x01 && minor <= 0x04
+}
+
+func tls13SupportedVersionsSeen(data []byte) bool {
+	for pos := 0; pos+4 <= len(data); {
+		if data[pos] == 0x00 && data[pos+1] == 0x2b {
+			extLen := int(data[pos+2])<<8 | int(data[pos+3])
+			extStart := pos + 4
+			extEnd := extStart + extLen
+			if extEnd > len(data) {
+				extEnd = len(data)
+			}
+			for scan := extStart; scan+2 <= extEnd; scan++ {
+				if data[scan] == 0x03 && data[scan+1] == 0x04 {
+					return true
+				}
+			}
+			pos = extEnd
+		} else {
+			pos++
+		}
+	}
+	return false
+}
+
+func writeFull(writer io.Writer, data []byte) error {
+	for len(data) > 0 {
+		n, err := writer.Write(data)
+		if err != nil {
+			return err
+		}
+		if n == 0 {
+			return io.ErrShortWrite
+		}
+		data = data[n:]
+	}
+	return nil
+}
+
+var _ net.Conn = (*shadowsocksTLSDirectConn)(nil)
+var _ io.Reader = (*shadowsocksTLSDirectConn)(nil)
+var _ io.Writer = (*shadowsocksTLSDirectConn)(nil)
