diff --git a/protocol/shadowsocks/tls_direct.go b/protocol/shadowsocks/tls_direct.go
new file mode 100644
index 00000000..ef71f91c
--- /dev/null
+++ b/protocol/shadowsocks/tls_direct.go
@@ -0,0 +1,228 @@
+package shadowsocks
+
+import (
+	"bytes"
+	"io"
+	"net"
+	"sync"
+	"time"
+)
+
+const tlsDirectMaxEncryptedPackets = 20
+
+var tlsDirectMarker = []byte("\x00ss-rust-tls-direct-v1\xff")
+
+type tlsDirectConn struct {
+	net.Conn
+	rawConn net.Conn
+
+	readAccess sync.Mutex
+	readPlain  bool
+	readBuffer []byte
+
+	writeAccess sync.Mutex
+	writePlain  bool
+
+	stateAccess sync.Mutex
+	state       tlsDirectState
+}
+
+func newTLSDirectConn(conn net.Conn, rawConn net.Conn) net.Conn {
+	return &tlsDirectConn{
+		Conn:    conn,
+		rawConn: rawConn,
+	}
+}
+
+func (c *tlsDirectConn) Read(p []byte) (int, error) {
+	c.readAccess.Lock()
+	defer c.readAccess.Unlock()
+
+	if len(p) == 0 {
+		return 0, nil
+	}
+
+	if len(c.readBuffer) > 0 {
+		n := copy(p, c.readBuffer)
+		c.readBuffer = c.readBuffer[n:]
+		return n, nil
+	}
+
+	if c.readPlain {
+		return c.rawConn.Read(p)
+	}
+
+	buffer := make([]byte, 16*1024)
+	n, err := c.Conn.Read(buffer)
+	if n > 0 {
+		data := buffer[:n]
+		if bytes.HasPrefix(data, tlsDirectMarker) {
+			payload := data[len(tlsDirectMarker):]
+			c.readPlain = true
+			n = copy(p, payload)
+			if n < len(payload) {
+				c.readBuffer = append(c.readBuffer[:0], payload[n:]...)
+			}
+			return n, nil
+		}
+		c.observe(data)
+		n = copy(p, data)
+		if n < len(data) {
+			c.readBuffer = append(c.readBuffer[:0], data[n:]...)
+		}
+		return n, nil
+	}
+	return n, err
+}
+
+func (c *tlsDirectConn) Write(p []byte) (int, error) {
+	c.writeAccess.Lock()
+	defer c.writeAccess.Unlock()
+
+	if c.writePlain {
+		return c.rawConn.Write(p)
+	}
+
+	if c.shouldSwitchToDirect(p) {
+		buffer := make([]byte, 0, len(tlsDirectMarker)+len(p))
+		buffer = append(buffer, tlsDirectMarker...)
+		buffer = append(buffer, p...)
+		if err := writeFull(c.Conn, buffer); err != nil {
+			return 0, err
+		}
+		c.writePlain = true
+		return len(p), nil
+	}
+
+	return c.Conn.Write(p)
+}
+
+func (c *tlsDirectConn) observe(data []byte) {
+	c.stateAccess.Lock()
+	defer c.stateAccess.Unlock()
+	c.state.observe(data)
+}
+
+func (c *tlsDirectConn) shouldSwitchToDirect(data []byte) bool {
+	c.stateAccess.Lock()
+	defer c.stateAccess.Unlock()
+	return c.state.shouldSwitchToDirect(data)
+}
+
+func (c *tlsDirectConn) Close() error {
+	return c.Conn.Close()
+}
+
+func (c *tlsDirectConn) LocalAddr() net.Addr {
+	return c.Conn.LocalAddr()
+}
+
+func (c *tlsDirectConn) RemoteAddr() net.Addr {
+	return c.Conn.RemoteAddr()
+}
+
+func (c *tlsDirectConn) SetDeadline(t time.Time) error {
+	return c.Conn.SetDeadline(t)
+}
+
+func (c *tlsDirectConn) SetReadDeadline(t time.Time) error {
+	return c.Conn.SetReadDeadline(t)
+}
+
+func (c *tlsDirectConn) SetWriteDeadline(t time.Time) error {
+	return c.Conn.SetWriteDeadline(t)
+}
+
+type tlsDirectState struct {
+	packetsSeen int
+	tlsSeen     bool
+	tls13Seen   bool
+}
+
+func (s *tlsDirectState) observe(data []byte) {
+	if len(data) == 0 {
+		return
+	}
+
+	s.packetsSeen++
+
+	if len(data) < 6 || data[1] != 0x03 {
+		return
+	}
+
+	switch data[0] {
+	case 0x16:
+		handshakeType := data[5]
+		if handshakeType == 0x01 {
+			s.tlsSeen = true
+		} else if handshakeType == 0x02 {
+			s.tlsSeen = true
+			if serverHelloHasTLS13SupportedVersions(data) {
+				s.tls13Seen = true
+			}
+		}
+	case 0x17:
+		if isTLSRecordVersion(data[1], data[2]) && s.tlsSeen && s.packetsSeen >= tlsDirectMaxEncryptedPackets {
+			return
+		}
+	}
+}
+
+func (s *tlsDirectState) shouldSwitchToDirect(data []byte) bool {
+	s.observe(data)
+	return s.tlsSeen &&
+		isCompleteTLSApplicationData(data) &&
+		(s.tls13Seen || s.packetsSeen >= tlsDirectMaxEncryptedPackets)
+}
+
+func isCompleteTLSApplicationData(data []byte) bool {
+	for len(data) > 0 {
+		if len(data) < 5 {
+			return false
+		}
+		if data[0] != 0x17 || !isTLSRecordVersion(data[1], data[2]) {
+			return false
+		}
+		recordLen := int(data[3])<<8 | int(data[4])
+		data = data[5:]
+		if len(data) < recordLen {
+			return false
+		}
+		data = data[recordLen:]
+	}
+	return true
+}
+
+func isTLSRecordVersion(major byte, minor byte) bool {
+	return major == 0x03 && minor >= 0x01 && minor <= 0x04
+}
+
+func serverHelloHasTLS13SupportedVersions(data []byte) bool {
+	if len(data) < 5 {
+		return false
+	}
+	recordLen := int(data[3])<<8 | int(data[4])
+	end := 5 + recordLen
+	if end > len(data) {
+		end = len(data)
+	}
+	return bytes.Contains(data[:end], []byte{0x00, 0x2b, 0x00, 0x02, 0x03, 0x04})
+}
+
+func writeFull(writer io.Writer, data []byte) error {
+	for len(data) > 0 {
+		n, err := writer.Write(data)
+		if err != nil {
+			return err
+		}
+		if n == 0 {
+			return io.ErrShortWrite
+		}
+		data = data[n:]
+	}
+	return nil
+}
+
+var _ net.Conn = (*tlsDirectConn)(nil)
+var _ io.Reader = (*tlsDirectConn)(nil)
+var _ io.Writer = (*tlsDirectConn)(nil)
